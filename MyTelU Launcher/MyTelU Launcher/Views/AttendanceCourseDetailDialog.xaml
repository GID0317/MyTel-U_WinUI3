<ContentDialog
    x:Class="MyTelU_Launcher.Views.AttendanceCourseDetailDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MyTelU_Launcher.Models"
    xmlns:helpers="using:MyTelU_Launcher.Helpers"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    Style="{StaticResource DefaultContentDialogStyle}"
    Title="Session Detail"
    CloseButtonText="Close"
    DefaultButton="Close">

    <ContentDialog.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="PresentBrush"  Color="#4EC94E"/>
                    <SolidColorBrush x:Key="AbsentBrush"   Color="#FF6B6B"/>
                    <SolidColorBrush x:Key="ExcusedBrush"  Color="#FFD42E"/>
                    <SolidColorBrush x:Key="BadgeTextBrush" Color="#1C1C1C"/>
                    <x:Double x:Key="ContentDialogMinWidth">560</x:Double>
                    <x:Double x:Key="ContentDialogMaxWidth">560</x:Double>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="PresentBrush"  Color="#1A7F1A"/>
                    <SolidColorBrush x:Key="AbsentBrush"   Color="#C42B1C"/>
                    <SolidColorBrush x:Key="ExcusedBrush"  Color="#B07800"/>
                    <SolidColorBrush x:Key="BadgeTextBrush" Color="#FFFFFF"/>
                    <x:Double x:Key="ContentDialogMinWidth">560</x:Double>
                    <x:Double x:Key="ContentDialogMaxWidth">560</x:Double>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="PresentBrush"  Color="#4EC94E"/>
                    <SolidColorBrush x:Key="AbsentBrush"   Color="#FF6B6B"/>
                    <SolidColorBrush x:Key="ExcusedBrush"  Color="#FFD42E"/>
                    <SolidColorBrush x:Key="BadgeTextBrush" Color="#1C1C1C"/>
                    <x:Double x:Key="ContentDialogMinWidth">560</x:Double>
                    <x:Double x:Key="ContentDialogMaxWidth">560</x:Double>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <helpers:BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
            <!-- Remove the 58px left / 44px right default item indent -->
            <Thickness x:Key="SettingsExpanderItemPadding">16,8,16,8</Thickness>

        </ResourceDictionary>
    </ContentDialog.Resources>

    <ScrollViewer MaxHeight="560" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="0">

        <!-- Loading -->
        <StackPanel x:Name="LoadingPanel"
                    Spacing="12" Padding="0,20"
                    HorizontalAlignment="Center"
                    Visibility="Collapsed">
            <ProgressRing x:Name="LoadingRing"
                          IsActive="True" Width="48" Height="48"
                          HorizontalAlignment="Center"/>
            <TextBlock Text="Loading sessions…"
                       FontSize="13" Opacity="0.6"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Empty state (no course header shown) -->
        <StackPanel x:Name="EmptyPanel"
                    Spacing="24" Padding="0,20"
                    HorizontalAlignment="Center"
                    Visibility="Collapsed">
            <Grid x:Name="MascotContainer" Width="160" Height="160"
                  HorizontalAlignment="Center" Loaded="MascotContainer_Loaded"/>
            <TextBlock Text="No session records found for this course!"
                       FontSize="16" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Opacity="0.7"/>
        </StackPanel>

        <!-- Course header + sessions (only shown when sessions exist) -->
        <controls:SettingsExpander x:Name="CourseExpander"
                                   IsExpanded="True"
                                   Visibility="Collapsed">

            <controls:SettingsExpander.Header>
                <StackPanel Spacing="3">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock x:Name="CourseCodeText"
                                   FontSize="14" FontWeight="Bold"/>
                        <TextBlock x:Name="ClassCodeText"
                                   FontSize="12" Opacity="0.55" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="CourseNameText"
                               FontSize="13" Opacity="0.7" TextWrapping="Wrap"/>
                </StackPanel>
            </controls:SettingsExpander.Header>

            <controls:SettingsExpander.ItemTemplate>
                <DataTemplate x:DataType="models:AttendanceSessionDetail">
                    <controls:SettingsCard>

                        <controls:SettingsCard.Header>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border Width="30" Height="30"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="4">
                                    <TextBlock Text="{x:Bind No}"
                                               FontSize="12" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind Date}"
                                               FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="{x:Bind Day}"
                                               FontSize="12" Opacity="0.55"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="·" FontSize="12" Opacity="0.35" VerticalAlignment="Center"/>
                                    <TextBlock FontSize="12" Opacity="0.7" VerticalAlignment="Center">
                                        <Run Text="{x:Bind StartTime}"/><Run Text=" – "/><Run Text="{x:Bind EndTime}"/>
                                    </TextBlock>
                                    <TextBlock Text="·" FontSize="12" Opacity="0.35" VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind Lecturer}" FontSize="12" Opacity="0.7" VerticalAlignment="Center"/>
                                    <TextBlock Text="·" FontSize="12" Opacity="0.35" VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind SessionType}" FontSize="12" Opacity="0.7" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </controls:SettingsCard.Header>

                        <controls:SettingsCard.Description>
                            <TextBlock Text="{x:Bind Content}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       IsTextSelectionEnabled="True"
                                       SelectionHighlightColor="{ThemeResource AccentFillColorDefaultBrush}"
                                       Visibility="{x:Bind HasContent, Converter={StaticResource BoolToVisibility}}"/>
                        </controls:SettingsCard.Description>

                        <StackPanel VerticalAlignment="Center">
                            <Border Padding="8,3" CornerRadius="4"
                                    Background="{ThemeResource PresentBrush}"
                                    Visibility="{x:Bind IsPresent, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="Hadir" FontSize="10" FontWeight="Bold"
                                           Foreground="{ThemeResource BadgeTextBrush}"/>
                            </Border>
                            <Border Padding="8,3" CornerRadius="4"
                                    Background="{ThemeResource AbsentBrush}"
                                    Visibility="{x:Bind IsAbsent, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="Alpa" FontSize="10" FontWeight="Bold"
                                           Foreground="{ThemeResource BadgeTextBrush}"/>
                            </Border>
                            <Border Padding="8,3" CornerRadius="4"
                                    Background="{ThemeResource ExcusedBrush}"
                                    Visibility="{x:Bind IsExcused, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="Izin" FontSize="10" FontWeight="Bold"
                                           Foreground="{ThemeResource BadgeTextBrush}"/>
                            </Border>
                        </StackPanel>

                    </controls:SettingsCard>
                </DataTemplate>
            </controls:SettingsExpander.ItemTemplate>

        </controls:SettingsExpander>

    </StackPanel>
    </ScrollViewer>
</ContentDialog>
