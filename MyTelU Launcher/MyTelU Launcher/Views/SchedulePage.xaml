<Page
    x:Class="MyTelU_Launcher.Views.SchedulePage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:behaviors="using:MyTelU_Launcher.Behaviors"
    xmlns:helpers="using:MyTelU_Launcher.Helpers"
    xmlns:models="using:MyTelU_Launcher.Models"
    xmlns:local="using:MyTelU_Launcher.Views"
    xmlns:ctControls="using:CommunityToolkit.WinUI.Controls"
    xmlns:animations="using:CommunityToolkit.WinUI.Animations"
    behaviors:NavigationViewHeaderBehavior.HeaderMode="Never"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <!-- Dark in dark: text colour matches dark-theme base, not white -->
                    <SolidColorBrush x:Key="TimetableHeaderTextBrush" Color="#1C1C1C"/>
                    <SolidColorBrush x:Key="TimetableHeaderSeparatorBrush" Color="#1C1C1C"/>
                    <!-- Badge backgrounds: bright/vivid for dark theme -->
                    <SolidColorBrush x:Key="BadgeTextBrush"       Color="#1C1C1C"/>
                    <SolidColorBrush x:Key="BadgeFinishedBrush"   Color="#4EC94E"/>
                    <SolidColorBrush x:Key="BadgeOngoingBrush"    Color="#FFD42E"/>
                    <SolidColorBrush x:Key="BadgeUpcomingBrush"   Color="#5AADFF"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <!-- Light in light: text colour matches light-theme base, not dark -->
                    <SolidColorBrush x:Key="TimetableHeaderTextBrush" Color="#F2F2F2"/>
                    <SolidColorBrush x:Key="TimetableHeaderSeparatorBrush" Color="#F2F2F2"/>
                    <!-- Badge backgrounds: deeper/saturated for light theme -->
                    <SolidColorBrush x:Key="BadgeTextBrush"       Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="BadgeFinishedBrush"   Color="#1A7F1A"/>
                    <SolidColorBrush x:Key="BadgeOngoingBrush"    Color="#B07800"/>
                    <SolidColorBrush x:Key="BadgeUpcomingBrush"   Color="#0055B3"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <helpers:BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
            <Style x:Key="DisabledDayStyle" TargetType="ctControls:SegmentedItem">
                <Setter Property="IsEnabled" Value="False"/>
                <Setter Property="Opacity" Value="0.35"/>
            </Style>
            <local:DaySegmentStyleSelector x:Key="DayStyleSelector"
                                           DisabledStyle="{StaticResource DisabledDayStyle}"/>

            <!-- Implicit animation sets for show/hide transitions -->
            <animations:ImplicitAnimationSet x:Name="ShowTransitions">
                <animations:OffsetAnimation EasingMode="EaseOut"
                                            From="0,16,0" To="0"
                                            Duration="0:0:0.35"/>
                <animations:OpacityAnimation EasingMode="EaseOut"
                                             From="0" To="1"
                                             Duration="0:0:0.25"/>
            </animations:ImplicitAnimationSet>
            <animations:ImplicitAnimationSet x:Name="HideTransitions">
                <animations:OffsetAnimation EasingMode="EaseOut"
                                            From="0" To="0,8,0"
                                            Duration="0:0:0.15"/>
                <animations:OpacityAnimation EasingMode="EaseOut"
                                             From="1" To="0"
                                             Duration="0:0:0.1"/>
            </animations:ImplicitAnimationSet>

            <!-- Directional slide animations for segment day switching -->
            <animations:ImplicitAnimationSet x:Name="SlideShowFromRight">
                <animations:OffsetAnimation EasingMode="EaseOut" From="40,0,0" To="0" Duration="0:0:0.3"/>
                <animations:OpacityAnimation EasingMode="EaseOut" From="0" To="1" Duration="0:0:0.25"/>
            </animations:ImplicitAnimationSet>
            <animations:ImplicitAnimationSet x:Name="SlideShowFromLeft">
                <animations:OffsetAnimation EasingMode="EaseOut" From="-40,0,0" To="0" Duration="0:0:0.3"/>
                <animations:OpacityAnimation EasingMode="EaseOut" From="0" To="1" Duration="0:0:0.25"/>
            </animations:ImplicitAnimationSet>
            <animations:ImplicitAnimationSet x:Name="SlideHideToLeft">
                <animations:OffsetAnimation EasingMode="EaseOut" From="0" To="-40,0,0" Duration="0:0:0.15"/>
                <animations:OpacityAnimation EasingMode="EaseOut" From="1" To="0" Duration="0:0:0.1"/>
            </animations:ImplicitAnimationSet>
            <animations:ImplicitAnimationSet x:Name="SlideHideToRight">
                <animations:OffsetAnimation EasingMode="EaseOut" From="0" To="40,0,0" Duration="0:0:0.15"/>
                <animations:OpacityAnimation EasingMode="EaseOut" From="1" To="0" Duration="0:0:0.1"/>
            </animations:ImplicitAnimationSet>

            <!-- Drill-in/out for the login overlay -->
            <animations:ImplicitAnimationSet x:Name="DrillInShow">
                <animations:ScaleAnimation EasingMode="EaseOut" From="0.88,0.88,1" To="1,1,1" Duration="0:0:0.35"/>
                <animations:OpacityAnimation EasingMode="EaseOut" From="0" To="1" Duration="0:0:0.25"/>
            </animations:ImplicitAnimationSet>
            <animations:ImplicitAnimationSet x:Name="DrillOutHide">
                <animations:ScaleAnimation EasingMode="EaseIn" From="1,1,1" To="0.94,0.94,1" Duration="0:0:0.15"/>
                <animations:OpacityAnimation EasingMode="EaseIn" From="1" To="0" Duration="0:0:0.12"/>
            </animations:ImplicitAnimationSet>
        </ResourceDictionary>
    </Page.Resources>

    <!-- Root Grid for layering -->
    <Grid>
        <!-- Background Layer: Full-size acrylic rectangle -->
        <Rectangle Fill="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"
                   Margin="-100,-100,-100,-100"/>

        <!-- Foreground Content Layer -->
        <Grid x:Name="ContentArea" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header card -->
            <Border Grid.Row="0" Margin="0,0,0,12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Header Controls -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                        <ComboBox ItemsSource="{x:Bind ViewModel.AcademicYearOptions}"
                                  SelectedItem="{x:Bind ViewModel.SelectedAcademicYear, Mode=TwoWay}"
                                  DisplayMemberPath="Text"
                                  PlaceholderText="Academic Year"
                                  Width="200"/>
                    </StackPanel>

                    <!-- Action buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">

                        <!-- Refresh -->
                        <Button Command="{x:Bind ViewModel.RefreshScheduleCommand}"
                                IsEnabled="{x:Bind ViewModel.IsNotLoading, Mode=OneWay}">
                            <Grid MinWidth="80">
                                <StackPanel Orientation="Horizontal" Spacing="8"
                                            Visibility="{x:Bind ViewModel.IsNotLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                    <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                                    <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                                </StackPanel>
                                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                                              Width="16" Height="16"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>

                        <!-- View layout dropdown -->
                        <DropDownButton>
                            <DropDownButton.Content>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="{x:Bind ViewModel.CurrentLayoutIcon, Mode=OneWay}" FontSize="16"/>
                                    <TextBlock Text="View" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DropDownButton.Content>
                            <DropDownButton.Flyout>
                                <MenuFlyout Placement="Bottom">
                                    <RadioMenuFlyoutItem Text="List"
                                                        GroupName="LayoutGroup"
                                                        IsChecked="{x:Bind ViewModel.IsListLayout, Mode=OneWay}"
                                                        Command="{x:Bind ViewModel.SetListLayoutCommand}">
                                        <RadioMenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8FD;"/>
                                        </RadioMenuFlyoutItem.Icon>
                                    </RadioMenuFlyoutItem>
                                    <RadioMenuFlyoutItem Text="Table"
                                                        GroupName="LayoutGroup"
                                                        IsChecked="{x:Bind ViewModel.IsTableLayout, Mode=OneWay}"
                                                        Command="{x:Bind ViewModel.SetTableLayoutCommand}">
                                        <RadioMenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8A1;"/>
                                        </RadioMenuFlyoutItem.Icon>
                                    </RadioMenuFlyoutItem>
                                    <RadioMenuFlyoutItem Text="Timeline"
                                                        GroupName="LayoutGroup"
                                                        IsChecked="{x:Bind ViewModel.IsTimetableLayout, Mode=OneWay}"
                                                        Command="{x:Bind ViewModel.SetTimetableLayoutCommand}">
                                        <RadioMenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xECA5;"/>
                                        </RadioMenuFlyoutItem.Icon>
                                    </RadioMenuFlyoutItem>
                                </MenuFlyout>
                            </DropDownButton.Flyout>
                        </DropDownButton>

                        <!-- More (configure) -->
                        <Button Padding="7">
                            <FontIcon Glyph="&#xE712;" FontSize="16"/>
                            <Button.Flyout>
                                <MenuFlyout Placement="Bottom">
                                    <MenuFlyoutItem Text="More schedule information"
                                                   Command="{x:Bind ViewModel.OpenScheduleInBrowserCommand}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8A7;"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutSeparator/>
                                    <MenuFlyoutItem Text="Sign out and clear data"
                                                   Command="{x:Bind ViewModel.RequestClearSessionCommand}"
                                                   Foreground="{ThemeResource SystemFillColorCriticalBrush}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xF3B1;" 
                                                      Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>

                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content area -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <Border Margin="0,0,0,10"
                            Visibility="{x:Bind ViewModel.IsOffline, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <InfoBar Severity="Informational" IsClosable="False"
                                 Title="Offline mode"
                                 Message="{x:Bind ViewModel.CacheTimestampMessage, Mode=OneWay}"
                                 IsOpen="{x:Bind ViewModel.IsOffline, Mode=OneWay}">
                            <InfoBar.ActionButton>
                                <Button Command="{x:Bind ViewModel.RefreshScheduleCommand}"
                                        IsEnabled="{x:Bind ViewModel.IsNotLoading, Mode=OneWay}"
                                        CornerRadius="5"
                                        HorizontalAlignment="Right">
                                    <Grid MinWidth="54">
                                        <TextBlock Text="Refresh"
                                                   Visibility="{x:Bind ViewModel.IsNotLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                                                      Width="16" Height="16"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                            </InfoBar.ActionButton>
                        </InfoBar>
                    </Border>
                    <Border Margin="0,0,0,10"
                            Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <InfoBar Severity="Error"
                                 Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                                 IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"/>
                    </Border>
                </StackPanel>

                <!-- Shared slot for loading overlay AND actual content -->
                <Grid Grid.Row="1">

                    <!-- Loading overlay: visible during any loading, non-blocking (IsHitTestVisible=False). -->
                    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          IsHitTestVisible="False"
                          Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                          Width="48" Height="48"
                                          HorizontalAlignment="Center"/>
                            <TextBlock Text="Loading schedule…" FontSize="13" Opacity="0.6"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- substitute parent content grid -->
                    <Grid>
                    
                        <!-- ── EMPTY STATE OVERLAY ── -->
                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center"
                              Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                             <StackPanel Spacing="24" HorizontalAlignment="Center">
                                  <!-- Composition Masking Container -->
                                  <Grid x:Name="MascotContainer" Width="180" Height="180"
                                        HorizontalAlignment="Center" Loaded="MascotContainer_Loaded"/>
                                  
                                  <TextBlock Text="No schedule found in this periods!"
                                             FontSize="18" FontWeight="SemiBold"
                                             HorizontalAlignment="Center" Opacity="0.8"/>
                             </StackPanel>
                        </Grid>

                        <!-- ── Content: hidden while loading OR empty, animates in after ── -->
                        <Grid Visibility="{x:Bind ViewModel.IsNotLoadingAndNotEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                              animations:Implicit.ShowAnimations="{StaticResource ShowTransitions}"
                              animations:Implicit.HideAnimations="{StaticResource HideTransitions}">

                        <!-- ── LIST VIEW ── -->
                        <ScrollViewer
                              VerticalScrollBarVisibility="Auto"
                              Visibility="{x:Bind ViewModel.IsListLayout, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                              animations:Implicit.ShowAnimations="{StaticResource ShowTransitions}"
                              animations:Implicit.HideAnimations="{StaticResource HideTransitions}">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Courses, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:CourseItem">
                                <Grid Margin="0,0,0,8" Padding="12" CornerRadius="8"
                                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Day}" FontSize="13" FontWeight="Bold"/>
                                        <TextBlock Text="{x:Bind Time}" FontSize="11" Opacity="0.7" TextWrapping="Wrap"/>
                                        <!-- ONGOING badge -->
                                        <Border Margin="0,5,0,0" Padding="5,2" CornerRadius="4" HorizontalAlignment="Left"
                                                Background="{ThemeResource BadgeOngoingBrush}"
                                                Visibility="{x:Bind IsOngoing, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="ONGOING" FontSize="9" FontWeight="Bold"
                                                       Foreground="{ThemeResource BadgeTextBrush}"/>
                                        </Border>
                                        <!-- UPCOMING badge -->
                                        <Border Margin="0,5,0,0" Padding="5,2" CornerRadius="4" HorizontalAlignment="Left"
                                                Background="{ThemeResource BadgeUpcomingBrush}"
                                                Visibility="{x:Bind IsUpcoming, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="UPCOMING" FontSize="9" FontWeight="Bold"
                                                       Foreground="{ThemeResource BadgeTextBrush}"/>
                                        </Border>
                                        <!-- FINISHED badge -->
                                        <Border Margin="0,5,0,0" Padding="5,2" CornerRadius="4" HorizontalAlignment="Left"
                                                Background="{ThemeResource BadgeFinishedBrush}"
                                                Visibility="{x:Bind IsFinished, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="FINISHED" FontSize="9" FontWeight="Bold"
                                                       Foreground="{ThemeResource BadgeTextBrush}"/>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,8,0">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{x:Bind CourseCode}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <TextBlock Text="-" FontSize="15" FontWeight="SemiBold" Opacity="0.4" VerticalAlignment="Center"/>
                                            <TextBlock Text="{x:Bind CourseName}" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE707;" FontSize="11" Opacity="0.7"/>
                                                <TextBlock Text="{x:Bind Room}" FontSize="12" Opacity="0.8"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE716;" FontSize="11" Opacity="0.7"/>
                                                <TextBlock Text="{x:Bind Class}" FontSize="12" Opacity="0.8"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <TextBlock Text="{x:Bind Lecturer}" FontSize="11" Opacity="0.6" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <FontIcon Grid.Column="2" Glyph="&#xE814;" Foreground="Red"
                                              Visibility="{x:Bind HasConflict, Mode=OneWay}"
                                              ToolTipService.ToolTip="Schedule conflict detected"
                                              VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                        <!-- ── TABLE VIEW (all days as columns, courses stacked) ── -->
                        <ScrollViewer
                              HorizontalScrollMode="Enabled"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollMode="Disabled"
                              VerticalScrollBarVisibility="Hidden"
                              Visibility="{x:Bind ViewModel.IsTableLayout, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                              animations:Implicit.ShowAnimations="{StaticResource ShowTransitions}"
                              animations:Implicit.HideAnimations="{StaticResource HideTransitions}">
                            <ItemsControl ItemsSource="{x:Bind ViewModel.CoursesByDay, Mode=OneWay}"
                                          Margin="0,0,0,16">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="4"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:DayGroup">
                                        <Border Width="210" VerticalAlignment="Top"
                                                CornerRadius="8"
>
                                            <StackPanel>
                                                <!-- Day header strip -->
                                                <Border Background="{ThemeResource SystemAccentColor}"
                                                        CornerRadius="8" Height="40" Margin="0,0,0,8">
                                                    <TextBlock Text="{x:Bind Day}"
                                                               FontSize="13" FontWeight="Bold"
                                                               Foreground="{ThemeResource TimetableHeaderTextBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>

                                                <!-- Course cards -->
                                                <ItemsControl ItemsSource="{x:Bind Courses}"
                                                              Padding="0,0,0,4">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="models:CourseItem">
                                                            <Border Margin="0,0,0,3.5" Padding="10,8"
                                                                    CornerRadius="6"
                                                                    Height="160"
                                                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                                    BorderThickness="1">
                                                                <StackPanel Spacing="3">
                                                                    <TextBlock TextWrapping="Wrap" MaxLines="3" TextTrimming="CharacterEllipsis">
                                                                        <Run Text="{x:Bind CourseCode}" FontWeight="Bold" FontSize="12"/>
                                                                        <Run Text=" - " FontWeight="Bold" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                                        <Run Text="{x:Bind CourseName}" FontWeight="Bold" FontSize="12"/>
                                                                    </TextBlock>
                                                                    <TextBlock Text="{x:Bind Time}"
                                                                               FontSize="11" Opacity="0.6"
                                                                               FontWeight="SemiBold"/>
                                                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2,0,0">
                                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                                            <FontIcon Glyph="&#xE707;" FontSize="10" Opacity="0.7"/>
                                                                            <TextBlock Text="{x:Bind Room}" FontSize="10" Opacity="0.7"/>
                                                                        </StackPanel>
                                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                                            <FontIcon Glyph="&#xE716;" FontSize="10" Opacity="0.7"/>
                                                                            <TextBlock Text="{x:Bind Class}" FontSize="10" Opacity="0.7"/>
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                    <TextBlock Text="{x:Bind Lecturer}"
                                                                               FontSize="10" Opacity="0.5"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               MaxLines="2"
                                                                               TextWrapping="Wrap"/>
                                                                    <!-- Status badges -->
                                                                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,4,0,0">
                                                                        <Border Padding="5,2" CornerRadius="4"
                                                                                Background="{ThemeResource BadgeOngoingBrush}"
                                                                                Visibility="{x:Bind IsOngoing, Converter={StaticResource BoolToVisibility}}">
                                                                            <TextBlock Text="ONGOING" FontSize="9" FontWeight="Bold" Foreground="{ThemeResource BadgeTextBrush}"/>
                                                                        </Border>
                                                                        <Border Padding="5,2" CornerRadius="4"
                                                                                Background="{ThemeResource BadgeUpcomingBrush}"
                                                                                Visibility="{x:Bind IsUpcoming, Converter={StaticResource BoolToVisibility}}">
                                                                            <TextBlock Text="UPCOMING" FontSize="9" FontWeight="Bold" Foreground="{ThemeResource BadgeTextBrush}"/>
                                                                        </Border>
                                                                        <Border Padding="5,2" CornerRadius="4"
                                                                                Background="{ThemeResource BadgeFinishedBrush}"
                                                                                Visibility="{x:Bind IsFinished, Converter={StaticResource BoolToVisibility}}">
                                                                            <TextBlock Text="FINISHED" FontSize="9" FontWeight="Bold" Foreground="{ThemeResource BadgeTextBrush}"/>
                                                                        </Border>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- ── TIMETABLE VIEW (single-day, columns = per-hour sessions) ── -->
                        <Grid CornerRadius="8"
                              Visibility="{x:Bind ViewModel.IsTimetableLayout, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                              animations:Implicit.ShowAnimations="{StaticResource ShowTransitions}"
                              animations:Implicit.HideAnimations="{StaticResource HideTransitions}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>


                    <!-- Day picker (Segmented) -->
                    <ctControls:Segmented Grid.Row="0"
                                          ItemsSource="{x:Bind ViewModel.AllDayItems, Mode=OneWay}"
                                          SelectedItem="{x:Bind ViewModel.SelectedDayItem, Mode=TwoWay}"
                                          ItemContainerStyleSelector="{StaticResource DayStyleSelector}"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,0,10">
                        <ctControls:Segmented.ItemTemplate>
                            <DataTemplate x:DataType="models:DaySegmentItem">
                                <TextBlock Text="{x:Bind Day}" FontSize="13" FontWeight="SemiBold"/>
                            </DataTemplate>
                        </ctControls:Segmented.ItemTemplate>
                    </ctControls:Segmented>

                    <!-- Scrollable timetable for the selected day -->
                    <ScrollViewer Grid.Row="1"
                                  HorizontalScrollMode="Enabled"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollMode="Disabled"
                                  VerticalScrollBarVisibility="Hidden">
                        <StackPanel Margin="0,0,0,16"
                                    x:Name="TimetableContent"
                                    Visibility="{x:Bind ViewModel.IsTimetableContentVisible, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">

                            <!-- ── Hour ruler (header) — single accent strip ── -->
                            <Border Background="{ThemeResource SystemAccentColor}"
                                    CornerRadius="6" Height="44">
                                <StackPanel Orientation="Horizontal">

                                    <!-- COURSE corner: 158px = 150px label + 8px gap, keeps strip solid -->
                                    <Grid Width="158">
                                        <TextBlock Text="COURSE"
                                                   FontSize="11" FontWeight="Bold"
                                                   Foreground="{ThemeResource TimetableHeaderTextBrush}" CharacterSpacing="80"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                    </Grid>

                                    <!-- Time-slot cells: each exactly 180px, left separator inside -->
                                    <ItemsControl ItemsSource="{x:Bind ViewModel.TimetableTimeHeaders, Mode=OneWay}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <!-- Width=180 MUST match HourWidth in ViewModel -->
                                                <Grid Width="180">
                                                    <!-- Left separator -->
                                                    <Rectangle Width="2" HorizontalAlignment="Left"
                                                               Fill="{ThemeResource TimetableHeaderSeparatorBrush}" Opacity="0.35" Margin="0,8"/>
                                                    <TextBlock Text="{x:Bind}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{ThemeResource TimetableHeaderTextBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               TextAlignment="Center"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>
                            </Border>

                            <!-- ── Gantt rows: one course per row, offset by start time ── -->
                            <ItemsControl ItemsSource="{x:Bind ViewModel.TimetableCourseRows, Mode=OneWay}"
                                          Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:TimetableCourseRow">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">

                                            <!-- Fixed COURSE label column: 150px + 8px gap = 158px, matches header -->
                                            <Border Width="158" MinHeight="110" Margin="0,0,3,0"
                                                    CornerRadius="6"
                                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1">
                                                <StackPanel Padding="10,8" Spacing="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind Course.CourseCode}"
                                                               FontSize="11" FontWeight="Bold"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{x:Bind Course.CourseName}"
                                                               FontSize="10" Opacity="0.6"
                                                               TextWrapping="Wrap"/>
                                                    <!-- Status badges in the fixed column so they're always visible -->
                                                    <Border Padding="5,2" CornerRadius="4" Margin="0,4,0,0"
                                                            Background="{ThemeResource BadgeOngoingBrush}"
                                                            HorizontalAlignment="Left"
                                                            Visibility="{x:Bind Course.IsOngoing, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock Text="ONGOING" FontSize="9" FontWeight="Bold" Foreground="{ThemeResource BadgeTextBrush}"/>
                                                    </Border>
                                                    <Border Padding="5,2" CornerRadius="4" Margin="0,4,0,0"
                                                            Background="{ThemeResource BadgeUpcomingBrush}"
                                                            HorizontalAlignment="Left"
                                                            Visibility="{x:Bind Course.IsUpcoming, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock Text="UPCOMING" FontSize="9" FontWeight="Bold" Foreground="{ThemeResource BadgeTextBrush}"/>
                                                    </Border>
                                                    <Border Padding="5,2" CornerRadius="4" Margin="0,4,0,0"
                                                            Background="{ThemeResource BadgeFinishedBrush}"
                                                            HorizontalAlignment="Left"
                                                            Visibility="{x:Bind Course.IsFinished, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock Text="FINISHED" FontSize="9" FontWeight="Bold" Foreground="{ThemeResource BadgeTextBrush}"/>
                                                    </Border>
                                                </StackPanel>
                                            </Border>

                                            <!-- Invisible spacer: pushes card to the correct time column -->
                                            <Border Width="{x:Bind LeftOffset}" Height="1" Opacity="0"/>

                                            <!-- Course card: width proportional to duration -->
                                            <Border Width="{x:Bind CardWidth}" MinHeight="110"
                                                    CornerRadius="6"
                                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1">
                                                <StackPanel Padding="12,10" Spacing="4">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Text="{x:Bind Course.CourseCode}"
                                                                   FontSize="13" FontWeight="Bold"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Text="-" FontSize="13" FontWeight="Bold"
                                                                   Opacity="0.4" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{x:Bind Course.CourseName}"
                                                                   FontSize="13" FontWeight="Bold"
                                                                   TextWrapping="Wrap"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{x:Bind Course.Time}"
                                                               FontSize="11" Opacity="0.65" FontWeight="SemiBold"/>
                                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <FontIcon Glyph="&#xE707;" FontSize="10" Opacity="0.7"/>
                                                            <TextBlock Text="{x:Bind Course.Room}" FontSize="11" Opacity="0.8"/>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <FontIcon Glyph="&#xE716;" FontSize="10" Opacity="0.7"/>
                                                            <TextBlock Text="{x:Bind Course.Class}" FontSize="11" Opacity="0.8"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <TextBlock Text="{x:Bind Course.Lecturer}"
                                                               FontSize="10" Opacity="0.5"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>

                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>
                    </Grid><!-- /timetable view -->

                    </Grid><!-- /content wrapper (IsNotLoading) -->
                    </Grid><!-- /wrapper for empty state + content -->
                </Grid><!-- /shared slot -->

            </Grid>
        </Grid>

        <!-- LOGIN OVERLAY: shown whenever not logged in -->
        <Grid x:Name="LoginOverlay"
              Visibility="{x:Bind ViewModel.NeedsLogin, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
              animations:Implicit.ShowAnimations="{StaticResource DrillInShow}"
              animations:Implicit.HideAnimations="{StaticResource DrillOutHide}">

            <!-- Backdrop -->
            <Rectangle Fill="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                       HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                       Opacity="0.98"/>

            <!-- Two-column layout -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Welcome content -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center"
                            Margin="60,0,40,0" Spacing="0">



                    <!-- Title -->
                    <TextBlock Text="Let&#x2019;s set up your schedule!"
                               FontSize="34" FontWeight="Bold"
                               TextWrapping="Wrap" Margin="0,0,0,14"/>

                    <!-- Subtitle -->
                    <TextBlock FontSize="14" Opacity="0.65" TextWrapping="Wrap"
                               Margin="0,0,0,36" LineHeight="22">
                        View your iGracias academic timetable right here sorted by day,
                        with a Gantt-style timeline showing how your courses progress
                        through the day. Log in once and your schedule stays synced.
                    </TextBlock>

                    <!-- Feature list -->
                    <StackPanel Spacing="14" Margin="0,0,0,44" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Spacing="14">
                            <Border Background="{ThemeResource SystemAccentColor}"
                                    CornerRadius="6" Width="32" Height="32">
                                <FontIcon Glyph="&#xE8FD;" FontSize="14" Foreground="White"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="List view" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="Full course details at a glance" FontSize="12" Opacity="0.6"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="14">
                            <Border Background="{ThemeResource SystemAccentColor}"
                                    CornerRadius="6" Width="32" Height="32">
                                <FontIcon Glyph="&#xECA5;" FontSize="14" Foreground="White"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Timeline view" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="See your day&#x27;s course progression" FontSize="12" Opacity="0.6"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="14">
                            <Border Background="{ThemeResource SystemAccentColor}"
                                    CornerRadius="6" Width="32" Height="32">
                                <FontIcon Glyph="&#xEA39;" FontSize="14" Foreground="White"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Conflict detection" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="Overlapping classes flagged automatically" FontSize="12" Opacity="0.6"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Command="{x:Bind ViewModel.BeginLoginFromOnboardingCommand}"
                                Style="{ThemeResource AccentButtonStyle}"
                                FontSize="14" Padding="24,10">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE8A7;" FontSize="14"/>
                                <TextBlock Text="Log in to iGracias"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                </StackPanel>

                <!-- Right: Mascot panel -->
                <Grid Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Margin="0,32,48,32" CornerRadius="20">

                    <!-- Gradient background -->
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{ThemeResource SystemAccentColor}" Offset="0.0"/>
                            <GradientStop Color="Transparent" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Grid.Background>

                    <!-- Mascot image -->
                    <Image Source="ms-appx:///Assets/GalihKoper_Icon.png"
                           HorizontalAlignment="Center" VerticalAlignment="Bottom"
                           Margin="16,32,16,0"
                           MaxHeight="400"
                           Stretch="Uniform"/>

                </Grid>
            </Grid>

        </Grid>

    </Grid>
</Page>