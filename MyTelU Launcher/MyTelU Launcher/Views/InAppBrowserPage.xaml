<!-- InAppBrowserPage.xaml -->
<Page
    x:Class="MyTelU_Launcher.Views.InAppBrowserPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="ContentArea">
        <!-- Header UI with browser controls -->
        <Grid x:Name="BrowserUIPage" VerticalAlignment="Top" Height="98" Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}" Padding="0,10,0,0">
            <TextBlock x:Name="BrowserUIText" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            <TextBox x:Name="BrowserUITextBox" Margin="160,0,125,0" Height="31" IsReadOnly="True"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0" Spacing="5" HorizontalAlignment="Left">
                <Button x:Name="BrowserUIBtnBack" Style="{StaticResource AccentButtonStyle}" Padding="7" Width="45" CornerRadius="10" Click="BrowserUIBtnBack_Click"
                        ToolTipService.ToolTip="Go Back">
                    <FontIcon Glyph="&#xE72B;"/>
                </Button>
                <Button x:Name="BrowserUIBtnForward" Style="{StaticResource AccentButtonStyle}" Padding="7" Width="45" CornerRadius="10" Click="BrowserUIBtnForward_Click"
                        ToolTipService.ToolTip="Go Forward">
                    <FontIcon Glyph="&#xE72A;"/>
                </Button>
                <Button Style="{StaticResource AccentButtonStyle}" Padding="7" Width="45" CornerRadius="10" Click="BrowserUIBtnReload_Click"
                        ToolTipService.ToolTip="Reload">
                    <FontIcon Glyph="&#xE72C;" FontWeight="ExtraBold"/>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0" Spacing="5" HorizontalAlignment="Right">
                <Button Style="{StaticResource AccentButtonStyle}" Padding="7" Width="58" CornerRadius="10" Click="BrowserUIBtnOpenOnBrowser_Click"
                        ToolTipService.ToolTip="Open in Browser">
                    <FontIcon Glyph="&#xE8A7;"/>
                </Button>
                <Button Style="{StaticResource AccentButtonStyle}" Padding="7" Width="45" CornerRadius="10" Click="BrowserUIBtnClose_Click"
                        ToolTipService.ToolTip="Close">
                    <FontIcon Glyph="&#xE8BB;"/>
                </Button>
            </StackPanel>
            <ProgressBar x:Name="BrowserUIProgressBar" VerticalAlignment="Bottom" Margin="0,0,0,11" IsIndeterminate="True" Visibility="Collapsed"/>
        </Grid>
        <!-- Nested Frame for further navigation -->
        <Frame x:Name="ContentFrame" Margin="0,98,0,0">
            <Frame.ContentTransitions>
                <TransitionCollection>
                </TransitionCollection>
            </Frame.ContentTransitions>
        </Frame>
    </Grid>
</Page>
