<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="MyTelU_Launcher.Views.ManageToolsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MyTelU_Launcher.Models"
    mc:Ignorable="d"
    Style="{StaticResource DefaultContentDialogStyle}"
    Title="Add or Rearrange Tools"
    PrimaryButtonText="Close"
    SecondaryButtonText="Add"
    SecondaryButtonClick="BrowseButton_Click"
    DefaultButton="Primary">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Description -->
        <TextBlock Grid.Row="0"
                   Text="Manage your Tools by adding or removing tools from the list below."
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"/>

        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="1"
                      MaxHeight="400"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="24">
                <!-- Tools Section -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Tools"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                    
                    <GridView x:Name="ToolsGridView"
                              ItemsSource="{x:Bind ViewModel.Tools, Mode=OneWay}"
                              CanReorderItems="True"
                              AllowDrop="True"
                              CanDragItems="True"
                              SelectionMode="None"
                              IsItemClickEnabled="False">
                        <GridView.ItemContainerStyle>
                            <Style TargetType="GridViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Margin" Value="0"/>
                            </Style>
                        </GridView.ItemContainerStyle>
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="models:ToolItem">
                                <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                      BorderThickness="1"
                                      CornerRadius="4"
                                      Padding="12"
                                      Height="60"
                                      Margin="4"
                                      HorizontalAlignment="Stretch">
                                    <Grid.ContextFlyout>
                                        <MenuFlyout Opening="MenuFlyout_Opening">
                                            <MenuFlyoutItem Text="Move up"
                                                            Click="MoveUpButton_Click"
                                                            Tag="{x:Bind}">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE74A;"/>
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutItem Text="Move down"
                                                            Click="MoveDownButton_Click"
                                                            Tag="{x:Bind}">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE74B;"/>
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutSeparator/>
                                            <MenuFlyoutItem Text="Remove"
                                                            Click="RemoveButton_Click"
                                                            Tag="{x:Bind}">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE74D;"/>
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                        </MenuFlyout>
                                    </Grid.ContextFlyout>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Drag Handle Icon -->
                                    <FontIcon Grid.Column="0"
                                              Glyph="&#xE76F;"
                                              FontSize="16"
                                              Margin="0,0,12,0"
                                              VerticalAlignment="Center"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                    <!-- Tool Icon Emoji -->
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind Icon}"
                                               FontSize="20"
                                               Margin="0,0,12,0"
                                               VerticalAlignment="Center"/>

                                    <!-- Tool Info -->
                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Name}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{x:Bind Url}"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <!-- More Button with Menu Flyout -->
                                    <Button Grid.Column="3"
                                            Width="32"
                                            Height="32"
                                            Padding="0"
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            ToolTipService.ToolTip="More options">
                                        <Button.Content>
                                            <FontIcon Glyph="&#xE712;" FontSize="16"/>
                                        </Button.Content>
                                        <Button.Flyout>
                                            <MenuFlyout Placement="Bottom" Opening="MenuFlyout_Opening">
                                                <MenuFlyoutItem x:Name="ToolsMoveUpItem"
                                                                Text="Move up"
                                                                Click="MoveUpButton_Click"
                                                                Tag="{x:Bind}">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon Glyph="&#xE74A;"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutItem x:Name="ToolsMoveDownItem"
                                                                Text="Move down"
                                                                Click="MoveDownButton_Click"
                                                                Tag="{x:Bind}">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon Glyph="&#xE74B;"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutSeparator/>
                                                <MenuFlyoutItem Text="Remove"
                                                                Click="RemoveButton_Click"
                                                                Tag="{x:Bind}">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon Glyph="&#xE74D;"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                            </MenuFlyout>
                                        </Button.Flyout>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsStackPanel/>
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>
                    </GridView>
                </StackPanel>

                <!-- Community Tools Section -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Community Tools"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                    
                    <GridView x:Name="CommunityToolsGridView"
                              ItemsSource="{x:Bind ViewModel.CommunityTools, Mode=OneWay}"
                              CanReorderItems="True"
                              AllowDrop="True"
                              CanDragItems="True"
                              SelectionMode="None"
                              IsItemClickEnabled="False">
                        <GridView.ItemContainerStyle>
                            <Style TargetType="GridViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Margin" Value="0"/>
                            </Style>
                        </GridView.ItemContainerStyle>
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="models:ToolItem">
                                <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                      BorderThickness="1"
                                      CornerRadius="4"
                                      Padding="12"
                                      Height="60"
                                      Margin="4"
                                      HorizontalAlignment="Stretch">
                                    <Grid.ContextFlyout>
                                        <MenuFlyout Opening="MenuFlyout_Opening">
                                            <MenuFlyoutItem Text="Move up"
                                                            Click="MoveUpButton_Click"
                                                            Tag="{x:Bind}">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE74A;"/>
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutItem Text="Move down"
                                                            Click="MoveDownButton_Click"
                                                            Tag="{x:Bind}">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE74B;"/>
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutSeparator/>
                                            <MenuFlyoutItem Text="Remove"
                                                            Click="RemoveButton_Click"
                                                            Tag="{x:Bind}">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE74D;"/>
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                        </MenuFlyout>
                                    </Grid.ContextFlyout>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Drag Handle Icon -->
                                    <FontIcon Grid.Column="0"
                                              Glyph="&#xE76F;"
                                              FontSize="16"
                                              Margin="0,0,12,0"
                                              VerticalAlignment="Center"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                    <!-- Tool Icon Emoji -->
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind Icon}"
                                               FontSize="20"
                                               Margin="0,0,12,0"
                                               VerticalAlignment="Center"/>

                                    <!-- Tool Info -->
                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Name}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{x:Bind Url}"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <!-- More Button with Menu Flyout -->
                                    <Button Grid.Column="3"
                                            Width="32"
                                            Height="32"
                                            Padding="0"
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            ToolTipService.ToolTip="More options">
                                        <Button.Content>
                                            <FontIcon Glyph="&#xE712;" FontSize="16"/>
                                        </Button.Content>
                                        <Button.Flyout>
                                            <MenuFlyout Placement="Bottom" Opening="MenuFlyout_Opening">
                                                <MenuFlyoutItem x:Name="CommunityToolsMoveUpItem"
                                                                Text="Move up"
                                                                Click="MoveUpButton_Click"
                                                                Tag="{x:Bind}">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon Glyph="&#xE74A;"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutItem x:Name="CommunityToolsMoveDownItem"
                                                                Text="Move down"
                                                                Click="MoveDownButton_Click"
                                                                Tag="{x:Bind}">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon Glyph="&#xE74B;"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutSeparator/>
                                                <MenuFlyoutItem Text="Remove"
                                                                Click="RemoveButton_Click"
                                                                Tag="{x:Bind}">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon Glyph="&#xE74D;"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                            </MenuFlyout>
                                        </Button.Flyout>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsStackPanel/>
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>
                    </GridView>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ContentDialog>
