<Page
    x:Class="MyTelU_Launcher.Views.GradePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:behaviors="using:MyTelU_Launcher.Behaviors"
    xmlns:helpers="using:MyTelU_Launcher.Helpers"
    xmlns:models="using:MyTelU_Launcher.Models"
    xmlns:vm="using:MyTelU_Launcher.ViewModels"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:animations="using:CommunityToolkit.WinUI.Animations"
    behaviors:NavigationViewHeaderBehavior.HeaderMode="Never"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="GradeBadgeTextBrush"   Color="#1C1C1C"/>
                    <SolidColorBrush x:Key="GradeOkBrush"           Color="#4EC94E"/>
                    <SolidColorBrush x:Key="GradeProgressBrush"     Color="#5AADFF"/>
                    <SolidColorBrush x:Key="GradeRepeatBrush"       Color="#FF6B6B"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="GradeBadgeTextBrush"   Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="GradeOkBrush"           Color="#1A7F1A"/>
                    <SolidColorBrush x:Key="GradeProgressBrush"     Color="#0055B3"/>
                    <SolidColorBrush x:Key="GradeRepeatBrush"       Color="#C42B1C"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <helpers:BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

            <animations:ImplicitAnimationSet x:Name="ShowList">
                <animations:OffsetAnimation EasingMode="EaseOut" From="0,16,0" To="0" Duration="0:0:0.35"/>
                <animations:OpacityAnimation EasingMode="EaseOut" From="0" To="1" Duration="0:0:0.25"/>
            </animations:ImplicitAnimationSet>
            <animations:ImplicitAnimationSet x:Name="HideList">
                <animations:OffsetAnimation EasingMode="EaseOut" From="0" To="0,8,0" Duration="0:0:0.15"/>
                <animations:OpacityAnimation EasingMode="EaseOut" From="1" To="0" Duration="0:0:0.1"/>
            </animations:ImplicitAnimationSet>
            <animations:ImplicitAnimationSet x:Name="DrillInShow">
                <animations:ScaleAnimation EasingMode="EaseOut" From="0.88,0.88,1" To="1,1,1" Duration="0:0:0.35"/>
                <animations:OpacityAnimation EasingMode="EaseOut" From="0" To="1" Duration="0:0:0.25"/>
            </animations:ImplicitAnimationSet>
            <animations:ImplicitAnimationSet x:Name="DrillOutHide">
                <animations:ScaleAnimation EasingMode="EaseIn" From="1,1,1" To="0.94,0.94,1" Duration="0:0:0.15"/>
                <animations:OpacityAnimation EasingMode="EaseIn" From="1" To="0" Duration="0:0:0.12"/>
            </animations:ImplicitAnimationSet>
        </ResourceDictionary>
    </Page.Resources>

    <!-- Root Grid -->
    <Grid>
        <Rectangle Fill="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                   HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                   Margin="-100,-100,-100,-100"/>

        <!-- Main Content -->
        <Grid x:Name="ContentArea" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Filter / toolbar bar -->
            <Border Grid.Row="0" Margin="0,0,0,12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                        <!-- Single combined period picker -->
                        <ComboBox x:Name="PeriodComboBox"
                                  ItemsSource="{x:Bind ViewModel.PeriodOptions}"
                                  SelectedItem="{x:Bind ViewModel.SelectedPeriod, Mode=TwoWay}"
                                  DisplayMemberPath="Label"
                                  PlaceholderText="Select academic year"
                                  ToolTipService.ToolTip="Select academic year and semester"
                                  Width="200"/>
                        <!-- Refresh button -->
                        <Button Padding="7"
                                Command="{x:Bind ViewModel.RefreshGradesCommand}"
                                IsEnabled="{x:Bind ViewModel.IsNotRefreshing, Mode=OneWay}"
                                ToolTipService.ToolTip="Refresh grades">
                            <Grid Width="16" Height="16">
                                <FontIcon Glyph="&#xE72C;" FontSize="16"
                                          Visibility="{x:Bind ViewModel.IsNotRefreshing, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                                <ProgressRing IsActive="{x:Bind ViewModel.IsRefreshing, Mode=OneWay}"
                                              Visibility="{x:Bind ViewModel.IsRefreshing, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                                              Width="16" Height="16"/>
                            </Grid>
                        </Button>
                    </StackPanel>

                    <!-- Right side options menu -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button Padding="7" ToolTipService.ToolTip="More options">
                            <FontIcon Glyph="&#xE712;" FontSize="16"/>
                            <Button.Flyout>
                                <MenuFlyout Placement="Bottom">
                                    <MenuFlyoutItem Text="More grade information"
                                                    Command="{x:Bind ViewModel.OpenGradesInBrowserCommand}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8A7;"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutSeparator/>
                                    <MenuFlyoutItem Text="Sign out and clear data"
                                                    Command="{x:Bind ViewModel.RequestClearSessionCommand}"
                                                    Foreground="{ThemeResource SystemFillColorCriticalBrush}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xF3B1;"
                                                      Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- InfoBars -->
                <StackPanel Grid.Row="0">
                    <Border Margin="0,0,0,10"
                            Visibility="{x:Bind ViewModel.IsOffline, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <InfoBar Severity="Informational" IsClosable="False"
                                 Title="Offline mode"
                                 Message="{x:Bind ViewModel.CacheTimestampMessage, Mode=OneWay}"
                                 IsOpen="{x:Bind ViewModel.IsOffline, Mode=OneWay}">
                            <InfoBar.ActionButton>
                                <Button Command="{x:Bind ViewModel.RefreshGradesCommand}"
                                        IsEnabled="{x:Bind ViewModel.IsNotRefreshing, Mode=OneWay}"
                                        CornerRadius="5" HorizontalAlignment="Right">
                                    <Grid MinWidth="54">
                                        <TextBlock Text="Refresh"
                                                   Visibility="{x:Bind ViewModel.IsNotRefreshing, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <ProgressRing IsActive="{x:Bind ViewModel.IsRefreshing, Mode=OneWay}"
                                                      Visibility="{x:Bind ViewModel.IsRefreshing, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                                                      Width="16" Height="16"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                            </InfoBar.ActionButton>
                        </InfoBar>
                    </Border>
                    <Border Margin="0,0,0,10"
                            Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <InfoBar Severity="Error"
                                 Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                                 IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"/>
                    </Border>
                </StackPanel>

                <!-- Main content slot -->
                <Grid Grid.Row="1">

                    <!-- Loading overlay: visible during any loading, non-blocking (IsHitTestVisible=False). -->
                    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          IsHitTestVisible="False"
                          Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                          Width="48" Height="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="Loading grades…" FontSize="13" Opacity="0.6"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Empty state -->
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center"
                          Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Spacing="24" HorizontalAlignment="Center">
                            <Grid x:Name="GradeMascotContainer" Width="180" Height="180"
                                  HorizontalAlignment="Center" Loaded="GradeMascotContainer_Loaded"/>
                            <TextBlock Text="No grades found for this period!"
                                       FontSize="18" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" Opacity="0.8"/>
                        </StackPanel>
                    </Grid>

                    <!-- Grade list + summary -->
                    <Grid x:Name="GradeContentGrid"
                          Visibility="{x:Bind ViewModel.IsNotLoadingAndNotEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Summary cards -->
                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Margin="0,0,6,0" Padding="16,12" CornerRadius="8"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Total Courses" FontSize="12" Opacity="0.6"/>
                                    <TextBlock Text="{x:Bind ViewModel.TotalCourses, Mode=OneWay}"
                                               FontSize="28" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Margin="6,0,6,0" Padding="16,12" CornerRadius="8"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Completed" FontSize="12" Opacity="0.6"/>
                                    <TextBlock Text="{x:Bind ViewModel.CompletedCourses, Mode=OneWay}"
                                               FontSize="28" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Margin="6,0,6,0" Padding="16,12" CornerRadius="8"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{x:Bind ViewModel.CurrentGpaLabel, Mode=OneWay}" FontSize="12" Opacity="0.6"/>
                                    <TextBlock Text="{x:Bind ViewModel.CurrentGpa, Mode=OneWay}"
                                               FontSize="28" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="3" Margin="6,0,0,0" Padding="16,12" CornerRadius="8"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Total SKS" FontSize="12" Opacity="0.6"/>
                                    <TextBlock Text="{x:Bind ViewModel.TotalCredits, Mode=OneWay}"
                                               FontSize="28" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Grade list -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Grades}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="2"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="models:GradeItem">
                                        <controls:SettingsCard
                                            IsClickEnabled="True"
                                            Tag="{x:Bind}"
                                            Click="GradeCard_Click">
                                            <controls:SettingsCard.Header>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="{x:Bind CourseCode}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    <TextBlock Text="-" Opacity="0.4" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{x:Bind CourseName}" FontWeight="SemiBold" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </controls:SettingsCard.Header>
                                            <controls:SettingsCard.Description>
                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <FontIcon Glyph="&#xE917;" FontSize="11" Opacity="0.6" VerticalAlignment="Center"/>
                                                        <TextBlock FontSize="12" Opacity="0.7" VerticalAlignment="Center">
                                                            <Run Text="{x:Bind Credits}"/><Run Text=" SKS"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <FontIcon Glyph="&#xE787;" FontSize="11" Opacity="0.6" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{x:Bind Period}" FontSize="12" Opacity="0.7" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </controls:SettingsCard.Description>
                                            <!-- Right side: grade badge + grade point -->
                                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                <!-- Status / grade badges -->
                                                <Border Padding="8,3" CornerRadius="4"
                                                        Background="{ThemeResource GradeOkBrush}"
                                                        Visibility="{x:Bind IsCompleted, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="{x:Bind Grade}" FontSize="12" FontWeight="Bold"
                                                               Foreground="{ThemeResource GradeBadgeTextBrush}"/>
                                                </Border>
                                                <Border Padding="8,3" CornerRadius="4"
                                                        Background="{ThemeResource GradeProgressBrush}"
                                                        Visibility="{x:Bind InProgress, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="IN PROGRESS" FontSize="10" FontWeight="SemiBold"
                                                               Foreground="{ThemeResource GradeBadgeTextBrush}" CharacterSpacing="60"/>
                                                </Border>
                                                <Border Padding="8,3" CornerRadius="4"
                                                        Background="{ThemeResource GradeRepeatBrush}"
                                                        Visibility="{x:Bind IsRepeated, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="REPEATED" FontSize="10" FontWeight="SemiBold"
                                                               Foreground="{ThemeResource GradeBadgeTextBrush}" CharacterSpacing="60"/>
                                                </Border>
                                                <!-- Grade point -->
                                                <TextBlock Text="{x:Bind GradePoint}"
                                                           FontSize="16" FontWeight="SemiBold"
                                                           Opacity="{x:Bind GradePointOpacity}"
                                                           VerticalAlignment="Center" MinWidth="36"
                                                           TextAlignment="Right"/>
                                            </StackPanel>
                                        </controls:SettingsCard>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <!-- LOGIN OVERLAY: shown whenever not logged in -->
        <Grid x:Name="LoginOverlay"
              Visibility="{x:Bind ViewModel.NeedsLogin, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
              animations:Implicit.ShowAnimations="{StaticResource DrillInShow}"
              animations:Implicit.HideAnimations="{StaticResource DrillOutHide}">

            <Rectangle Fill="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                       HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                       Opacity="0.98"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Welcome content -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center"
                            Margin="60,0,40,0" Spacing="0">

                    <TextBlock Text="Let&#x2019;s check your grades!"
                               FontSize="34" FontWeight="Bold"
                               TextWrapping="Wrap" Margin="0,0,0,14"/>

                    <TextBlock FontSize="14" Opacity="0.65" TextWrapping="Wrap"
                               Margin="0,0,0,36" LineHeight="22">
                        View your iGracias grade records right here. Browse completed courses,
                        see component score breakdowns, and track your academic progress.
                        Log in once and it stays synced.
                    </TextBlock>

                    <StackPanel Spacing="12">
                        <Button Command="{x:Bind ViewModel.BeginLoginFromOnboardingCommand}"
                                Style="{ThemeResource AccentButtonStyle}"
                                FontSize="14" Padding="24,10">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE8A7;" FontSize="14"/>
                                <TextBlock Text="Log in to iGracias"/>
                            </StackPanel>
                        </Button>
                        <StackPanel Orientation="Horizontal" Spacing="10"
                                    Visibility="{x:Bind ViewModel.IsBrowserLoginRunning, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                                    Margin="0,6,0,0">
                            <ProgressRing IsActive="True" Width="20" Height="20"/>
                            <TextBlock Text="Opening browser..." VerticalAlignment="Center"
                                       FontSize="13" Opacity="0.7"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Right: Mascot panel -->
                <Grid Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Margin="0,32,48,32" CornerRadius="20">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{ThemeResource SystemAccentColor}" Offset="0.0"/>
                            <GradientStop Color="Transparent" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Grid.Background>

                    <Image Source="ms-appx:///Assets/GalihKoper_Icon.png"
                           HorizontalAlignment="Center" VerticalAlignment="Bottom"
                           Margin="16,32,16,0"
                           MaxHeight="400"
                           Stretch="Uniform"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
