<ContentDialog
    x:Class="MyTelU_Launcher.Views.GradeComponentDetailDialog"
    x:Name="RootDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MyTelU_Launcher.Models"
    xmlns:helpers="using:MyTelU_Launcher.Helpers"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    Style="{StaticResource DefaultContentDialogStyle}"
    Title="Score Detail"
    CloseButtonText="Close"
    DefaultButton="Close">

    <ContentDialog.Resources>
        <ResourceDictionary>
            <helpers:BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
            <x:Double x:Key="ContentDialogMinWidth">560</x:Double>
            <x:Double x:Key="ContentDialogMaxWidth">560</x:Double>
            <!-- Same as AttendanceCourseDetailDialog: overrides default 58px left item indent -->
            <Thickness x:Key="SettingsExpanderItemPadding">16,8,16,8</Thickness>
        </ResourceDictionary>
    </ContentDialog.Resources>

    <ScrollViewer MaxHeight="560" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="0">

            <!-- Loading -->
            <StackPanel x:Name="LoadingPanel" Spacing="12" Padding="0,20"
                        HorizontalAlignment="Center" Visibility="Collapsed">
                <ProgressRing x:Name="LoadingRing" IsActive="True" Width="48" Height="48"
                              HorizontalAlignment="Center"/>
                <TextBlock Text="Loading component scores…"
                           FontSize="13" Opacity="0.6" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- No components message -->
            <StackPanel x:Name="NoDataPanel" Spacing="24" Padding="0,20"
                        HorizontalAlignment="Center" Visibility="Collapsed">
                <Grid x:Name="DialogMascotContainer" Width="160" Height="160"
                      HorizontalAlignment="Center" Loaded="DialogMascotContainer_Loaded"/>
                <TextBlock x:Name="NoDataMessage"
                           FontSize="16" FontWeight="SemiBold" Opacity="0.7"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>

            <controls:SettingsExpander x:Name="CourseExpander"
                                       HorizontalAlignment="Stretch"
                                       IsExpanded="True"
                                       Visibility="Collapsed">

                <controls:SettingsExpander.Header>
                    <StackPanel Spacing="3">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Name="CourseCodeText"
                                       FontSize="14" FontWeight="Bold"/>
                            <TextBlock x:Name="CourseMetaText"
                                       FontSize="12" Opacity="0.55" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="CourseNameText"
                                   FontSize="13" Opacity="0.7" TextWrapping="Wrap"/>
                    </StackPanel>
                </controls:SettingsExpander.Header>

                <controls:SettingsExpander.Items>
                    <controls:SettingsCard IsClickEnabled="False"
                                           Padding="0"
                                           HorizontalAlignment="Stretch"
                                           HorizontalContentAlignment="Stretch">
                        <controls:SettingsCard.Header>
                                <Grid HorizontalAlignment="Stretch"
                                    Margin="2,0,-10,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                                                <Grid Padding="12,6,12,6"
                                      Grid.Row="0"
                                      HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="280"/>
                                        <ColumnDefinition Width="68"/>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="76"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="COMPONENT"
                                               FontSize="11" Opacity="0.5" FontWeight="SemiBold"
                                               CharacterSpacing="60"/>
                                    <TextBlock Grid.Column="1" Text="Score"
                                               FontSize="11" Opacity="0.5" FontWeight="SemiBold"
                                               CharacterSpacing="60" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="2" Text="Weight"
                                               FontSize="11" Opacity="0.5" FontWeight="SemiBold"
                                               CharacterSpacing="60" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="3" Text="Weighted"
                                               FontSize="11" Opacity="0.5" FontWeight="SemiBold"
                                               CharacterSpacing="60" TextAlignment="Right"/>
                                </Grid>

                                <Rectangle Height="1" Opacity="0.12"
                                           Grid.Row="1"
                                           Fill="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                           Margin="0,0,0,4"/>

                                <ItemsControl x:Name="ComponentList"
                                              Grid.Row="2"
                                              HorizontalAlignment="Stretch">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:GradeComponentScore">
                                            <Grid Padding="12,10,12,10"
                                                  HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                                                                        <ColumnDefinition Width="280"/>
                                                    <ColumnDefinition Width="68"/>
                                                    <ColumnDefinition Width="56"/>
                                                    <ColumnDefinition Width="76"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{x:Bind Component}"
                                                           FontSize="13"
                                                           VerticalAlignment="Center"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTipService.ToolTip="{x:Bind Component}"
                                                           MaxLines="1"/>
                                                <TextBlock Grid.Column="1" FontSize="13"
                                                           TextAlignment="Right" VerticalAlignment="Center">
                                                    <Run Text="{x:Bind Score}"/>
                                                </TextBlock>
                                                <TextBlock Grid.Column="2" FontSize="13"
                                                           TextAlignment="Right" VerticalAlignment="Center"
                                                           Opacity="0.6">
                                                    <Run Text="{x:Bind Percentage}"/>
                                                    <Run Text="%"/>
                                                </TextBlock>
                                                <TextBlock Grid.Column="3" FontSize="13" FontWeight="SemiBold"
                                                           TextAlignment="Right" VerticalAlignment="Center">
                                                    <Run Text="{x:Bind Weighted}"/>
                                                </TextBlock>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Rectangle Height="1" Opacity="0.12"
                             Grid.Row="3"
                                           Fill="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                           Margin="0,4,0,0"/>

                      <Grid Padding="12,10,12,10"
                          Grid.Row="4"
                                      HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="280"/>
                                        <ColumnDefinition Width="68"/>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="76"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Total"
                                               FontSize="13" FontWeight="SemiBold" Opacity="0.8"/>
                                    <TextBlock x:Name="WeightedTotalText" Grid.Column="3"
                                               FontSize="14" FontWeight="Bold"
                                               TextAlignment="Right"/>
                                </Grid>
                            </Grid>
                        </controls:SettingsCard.Header>
                    </controls:SettingsCard>
                </controls:SettingsExpander.Items>
            </controls:SettingsExpander>

        </StackPanel>
    </ScrollViewer>
</ContentDialog>
