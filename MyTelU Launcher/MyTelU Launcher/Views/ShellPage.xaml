<Page
    x:Class="MyTelU_Launcher.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:MyTelU_Launcher.Helpers"
    xmlns:behaviors="using:MyTelU_Launcher.Behaviors"
    xmlns:i="using:Microsoft.Xaml.Interactivity"
    mc:Ignorable="d"
    Loaded="OnLoaded">

    <Page.Resources>
        <helpers:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Page.Resources>

    <Grid>
        <!-- Overall Page Background -->
        <Grid.Background>
            <SolidColorBrush Color="Transparent"/>
        </Grid.Background>

        <!-- App Title Bar -->
        <Grid x:Name="AppTitleBar"
              Canvas.ZIndex="1"
              Height="{Binding ElementName=NavigationViewControl, Path=CompactPaneLength}"
              IsHitTestVisible="True"
              VerticalAlignment="Top">
            <Image Source="ms-appx:///Assets/Icon_App.ico"
                   HorizontalAlignment="Left"
                   Width="30"
                   Height="30"
                   Margin="20,0,0,0"/>
            <TextBlock x:Name="AppTitleBarText"
                       VerticalAlignment="Center"
                       TextWrapping="NoWrap"
                       FontWeight="Bold"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Margin="60,0,0,0"/>
        </Grid>

        <!-- NavigationView -->
        <NavigationView
            x:Name="NavigationViewControl"
            SelectionChanged="NavigationViewControl_SelectionChanged"
            Canvas.ZIndex="0"
            Background="Transparent"
            IsBackButtonVisible="Visible"
            IsBackEnabled="{x:Bind ViewModel.IsBackEnabled, Mode=OneWay}"
            SelectedItem="{x:Bind ViewModel.Selected, Mode=OneWay}"
            IsSettingsVisible="True"
            ExpandedModeThresholdWidth="1280"
            DisplayModeChanged="NavigationViewControl_DisplayModeChanged"
            Header="{x:Bind ((ContentControl)ViewModel.Selected).Content, Mode=OneWay}">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Home" helpers:NavigationHelper.NavigateTo="MyTelU_Launcher.ViewModels.HomeViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE80F;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemHeader Content="Utilities"/>
                <NavigationViewItem Content="Schedule" x:Name="ScheduleNavItem">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE787;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="AttendanceNavItem" Content="Atendance">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xEE6F;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <!-- Main Content Area -->
            <Grid Margin="0,-1,0,0">
                <!-- Background Image -->
                <Image Source="{x:Bind ViewModel.BackgroundImage, Mode=OneWay}"
                       Stretch="UniformToFill"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"
                       Canvas.ZIndex="-1"
                       Margin="0,-100,0,0"/>

                <InfoBar
                    x:Name="UpdateAvailableInfoBar"
                    Visibility="{x:Bind ViewModel.IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}"
                    Margin="10"
                    IsOpen="True"
                    Severity="Warning"
                    Title="New Update available!"
                    Canvas.ZIndex="2"
                    Message="A new update is available. We recommend updating to the latest version for an enhanced experience and new features.">
                    <InfoBar.ActionButton>
                        <Button Content="Download now" 
                                HorizontalAlignment="Right" 
                                CornerRadius="5"
                                Click="DownloadNowButton_Click"/>
                    </InfoBar.ActionButton>
                </InfoBar>

                <!-- Main Navigation Frame -->
                <ScrollViewer VerticalScrollMode="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Canvas.ZIndex="1">
                    <Frame x:Name="NavigationFrame">
                        <Frame.ContentTransitions>
                            <TransitionCollection>
                                <NavigationThemeTransition/>
                            </TransitionCollection>
                        </Frame.ContentTransitions>
                    </Frame>
                </ScrollViewer>
            </Grid>

            <NavigationView.HeaderTemplate>
                <DataTemplate>
                    <Grid>
                        <TextBlock Text="{Binding}" Style="{ThemeResource TitleTextBlockStyle}" Foreground="Red"/>
                    </Grid>
                </DataTemplate>
            </NavigationView.HeaderTemplate>

            <i:Interaction.Behaviors>
                <behaviors:NavigationViewHeaderBehavior DefaultHeader="{x:Bind ((ContentControl)ViewModel.Selected).Content, Mode=OneWay}">
                    <behaviors:NavigationViewHeaderBehavior.DefaultHeaderTemplate>
                        <DataTemplate>
                            <Grid>
                                <TextBlock Text="{Binding}" Style="{ThemeResource TitleTextBlockStyle}" Foreground="Red"/>
                            </Grid>
                        </DataTemplate>
                    </behaviors:NavigationViewHeaderBehavior.DefaultHeaderTemplate>
                </behaviors:NavigationViewHeaderBehavior>
            </i:Interaction.Behaviors>
        </NavigationView>

        <!-- Overlay Container: Displays on top of all UI when activated -->
        <Grid x:Name="OverlayContainer"
              Background="#80000000"
              Visibility="Collapsed"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              Canvas.ZIndex="10">
            <!-- Inner Frame to host the overlay content (e.g. InAppBrowserPage) -->
            <Frame x:Name="OverlayFrame"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch">
                <Frame.ContentTransitions>
                    <TransitionCollection>
                        <NavigationThemeTransition/>
                    </TransitionCollection>
                </Frame.ContentTransitions>
            </Frame>
        </Grid>
    </Grid>
</Page>
