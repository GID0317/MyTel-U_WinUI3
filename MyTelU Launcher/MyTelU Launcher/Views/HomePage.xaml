                                               FontWeight="SemiBold"
                                               FontSize="18"/>
                                    <ToggleSwitch OffContent="Hide Application List"
                                                  OnContent="Show Application List"
                                                  FontWeight="SemiBold"
                                                  Toggled="Applicationlist_Toggle"
                                                  IsOn="True"/>
                                </StackPanel>
                            </StackPanel>
                        </Flyout>
                    </FlyoutBase.AttachedFlyout>
                </Button>
            </Grid>
        </Grid>

        <!-- Bottom Right: Community Tools -->
        <Grid HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Grid Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                  Margin="0,0,0,30"
                  CornerRadius="10">
                <Button FontWeight="SemiBold"
                        FontSize="14"
                        Height="40"
                        Click="CommunityTool_Click">
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xEB41;" Margin="0,0,10,0"/>
                        <TextBlock Text="Community Tools"/>
                    </StackPanel>
                    <FlyoutBase.AttachedFlyout>
                        <Flyout x:Name="CustomFlyout"
                                Opening="CustomFlyout_Opening"
                                Closed="CustomFlyout_Closed"/>
                    </FlyoutBase.AttachedFlyout>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</Page>
