<Page
    x:Class="MyTelU_Launcher.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:behaviors="using:MyTelU_Launcher.Behaviors"
    xmlns:helpers="using:MyTelU_Launcher.Helpers"
    xmlns:models="using:MyTelU_Launcher.Models"
    behaviors:NavigationViewHeaderBehavior.HeaderMode="Never"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Page.Resources>
        <helpers:BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Page.Resources>

    <Page.Background>
        <SolidColorBrush Color="Transparent"/>
    </Page.Background>

    <Grid x:Name="AppListVew" Margin="20,20,20,0" Background="Transparent">
        
        <TextBlock x:Name="ApplicationListTxtTitle" FontWeight="SemiBold" Text="Application Hub" Margin="3,20,5,5" FontSize="32" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
        
        <!-- Horizontal Application List Container -->
        <ScrollViewer x:Name="AplicationListContainer"
                      Padding="0"
                      VerticalAlignment="Stretch"
                      HorizontalAlignment="Stretch"
                      HorizontalScrollMode="Enabled"
                      VerticalScrollMode="Disabled"
                      HorizontalScrollBarVisibility="Visible">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Spacing="15"
                        Margin="0,100,0,20">
                <!-- Item 1 -->
                <Grid Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}" CornerRadius="4">
                    <Button Click="MyTuctuc_Click"
                            Height="250"
                            Width="211"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <Image Source="ms-appx:///Assets/Img_Logo_TucTuc.png"
                                   Margin="0,0,50,50"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Top"
                                   Width="80"
                                   Height="80"/>
                            <TextBlock Text="My TucTuc"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       FontSize="20"
                                       Margin="0,-35,0,0"
                                       FontWeight="SemiBold"/>
                            <TextBlock FontSize="12"
                                       TextAlignment="Left"
                                       HorizontalAlignment="Stretch">
                                <Span>lakukan mobilisasi atau berkegiatan</Span>
                                <LineBreak/>
                                <Span>di lingkungan Telkom University</Span>
                                <LineBreak/>
                            </TextBlock>
                            <FontIcon Glyph="&#xE8A7;"
                                      Margin="0,20,0,0"
                                      HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Item 2 -->
                <Grid Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}" CornerRadius="4">
                    <Button Click="IGracias_Click"
                            Height="250"
                            Width="211"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <Image Source="ms-appx:///Assets/Img_Logo_IGracias.jpg"
                                   Margin="0,0,50,0"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Top"
                                   Width="60"
                                   Height="90"/>
                            <TextBlock Text="IGracias"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       FontSize="20"
                                       Margin="0,0,0,10"
                                       FontWeight="SemiBold"/>
                            <TextBlock FontSize="12"
                                       TextAlignment="Left"
                                       HorizontalAlignment="Stretch">
                                <Span>layanan civitas akademik Telkom</Span>
                                <LineBreak/>
                                <Span>University terkait kebutuhan</Span>
                                <LineBreak/>
                                <Span>akademik dan non akademik</Span>
                            </TextBlock>
                            <FontIcon Glyph="&#xE8A7;"
                                      Margin="0,20,0,0"
                                      HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Item 3 -->
                <Grid Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}" CornerRadius="4">
                    <Button Click="CeloeLMS_Click"
                            Height="250"
                            Width="211"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <Image Source="ms-appx:///Assets/Img_Logo_Celoe.png"
                                   Margin="0,0,50,20"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Top"
                                   Width="150"
                                   Height="60"/>
                            <TextBlock Text="LMS"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                            <TextBlock FontSize="12"
                                       TextAlignment="Left"
                                       HorizontalAlignment="Stretch"
                                       Margin="0,15,0,0">
                                <Span>platform online learning program </Span>
                                <LineBreak/>
                                <Span>studi reguler dan program studi</Span>
                                <LineBreak/>
                                <Span>PJJ Telkom University.</Span>
                            </TextBlock>
                            <FontIcon Glyph="&#xE8A7;"
                                      Margin="0,20,0,0"
                                      HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Item 4 -->
                <Grid Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}" CornerRadius="4">
                    <Button Click="Celoe_Click"
                            Height="250"
                            Width="211"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <Image Source="ms-appx:///Assets/Img_Logo_Celoe.png"
                                   Margin="0,0,50,30"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Top"
                                   Width="150"
                                   Height="60"/>
                            <TextBlock Text="CeLOE"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                            <TextBlock FontSize="12"
                                       TextAlignment="Left"
                                       HorizontalAlignment="Stretch"
                                       Margin="0,10,0,0">
                                <Span>Center of ELearning and Open </Span>
                                <LineBreak/>
                                <Span>education Telkom University</Span>
                            </TextBlock>
                            <FontIcon Glyph="&#xE8A7;"
                                      Margin="0,30,0,0"
                                      HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Item 5 -->
                <Grid Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}" CornerRadius="4">
                    <Button Click="Sirama_Click"
                            Height="250"
                            Width="211"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <Image Source="ms-appx:///Assets/Img_Logo_Sirama.png"
                                   Margin="0,0,0,30"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Top"
                                   Width="150"
                                   Height="60"/>
                            <TextBlock Text="Sirama"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                            <TextBlock FontSize="12"
                                       TextAlignment="Left"
                                       HorizontalAlignment="Stretch"
                                       Margin="0,10,0,0">
                                <Span>Sistem Registrasi Akademik</Span>
                                <LineBreak/>
                                <Span>Mahasiswa Telkom University</Span>
                            </TextBlock>
                            <FontIcon Glyph="&#xE8A7;"
                                      Margin="0,30,0,0"
                                      HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Item 6 -->
                <Grid Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}" CornerRadius="4">
                    <Button Click="CampusLive_Click"
                            Height="250"
                            Width="211"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <Image Source="ms-appx:///Assets/Img_Logo_Campuslive.png"
                                   Margin="0,0,0,0"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Top"
                                   Width="150"
                                   Height="70"/>
                            <TextBlock Text="Campus Live"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       FontSize="20"
                                       Margin="0,10,0,0"
                                       FontWeight="SemiBold"/>
                            <TextBlock FontSize="12"
                                       TextAlignment="Left"
                                       HorizontalAlignment="Stretch"
                                       Margin="0,10,0,0">
                                <Span>interaksi dengan teman sekelas,</Span>
                                <LineBreak/>
                                <Span>dosen, staf kampus, dan</Span>
                                <LineBreak/>
                                <Span>masyarakat sekitar.</Span>
                            </TextBlock>
                            <FontIcon Glyph="&#xE8A7;"
                                      Margin="0,20,0,0"
                                      HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Item 7 -->
                <Grid Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}" CornerRadius="4">
                    <Button Click="TOS_Click"
                            Height="250"
                            Width="211"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <Image Source="ms-appx:///Assets/Img_Logo_TOSS.png"
                                   Margin="0,0,50,30"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Top"
                                   Width="150"
                                   Height="56"/>
                            <TextBlock Text="TOS"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       FontSize="20"
                                       Margin="0,-10,0,0"
                                       FontWeight="SemiBold"/>
                            <TextBlock FontSize="12"
                                       TextAlignment="Left"
                                       HorizontalAlignment="Stretch"
                                       Margin="0,10,0,0">
                                <Span>layanan administrasi Surat Aktif</Span>
                                <LineBreak/>
                                <Span>Mahasiswa, Pengantar Mata Kuliah,</Span>
                                <LineBreak/>
                                <Span>Pengantar Tugas Akhir.</Span>
                            </TextBlock>
                            <FontIcon Glyph="&#xE8A7;"
                                      Margin="0,20,0,0"
                                      HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Item 8 -->
                <Grid Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}" CornerRadius="4">
                    <Button Click="OpenLibrary_Click"
                            Height="250"
                            Width="211"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <Image Source="ms-appx:///Assets/Img_Logo_OpenLibrary.png"
                                   Margin="0,-10,50,0"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Top"
                                   Width="80"
                                   Height="80"/>
                            <TextBlock Text="Open Library"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                            <TextBlock FontSize="12"
                                       TextAlignment="Left"
                                       HorizontalAlignment="Stretch"
                                       Margin="0,10,0,0">
                                <Span>Sumber Daya Keilmuan dan</Span>
                                <LineBreak/>
                                <Span>Perpustakaan Telkom University</Span>
                            </TextBlock>
                            <FontIcon Glyph="&#xE8A7;"
                                      Margin="0,33,0,0"
                                      HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Item 9 -->
                <Grid Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}" CornerRadius="4">
                    <Button Click="SatuTlU_Click"
Height="250"
Width="211"
HorizontalAlignment="Center"
VerticalAlignment="Center">
                        <StackPanel>
                            <Image Source="ms-appx:///Assets/Img_Logo_SatuTelU.png"
       Margin="0,0,50,10"
       HorizontalAlignment="Left"
       VerticalAlignment="Top"
       Width="80"
       Height="65"/>
                            <TextBlock Text="Satu Tel-U"
           HorizontalAlignment="Center"
           TextAlignment="Center"
           FontSize="20"
           FontWeight="SemiBold"/>
                            <TextBlock FontSize="12"
           TextAlignment="Left"
           HorizontalAlignment="Stretch"
           Margin="0,10,0,0">
        <Span>Integrasi semua aplikasi yang</Span>
        <LineBreak/>
        <Span>dikelola oleh Direktorat Pusat</Span>
        <LineBreak/>
        <Span>Teknologi Informasi</Span>
                            </TextBlock>
                            <FontIcon Glyph="&#xE8A7;"
          Margin="0,20,0,0"
          HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Item 10 -->
                <Grid Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}" CornerRadius="4">
                    <Button Click="TAK_Click"
                            Height="250"
                            Width="211"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <Image Source="ms-appx:///Assets/Img_Logo_Situ.png"
                                   Margin="0,0,50,10"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Top"
                                   Width="80"
                                   Height="65"/>
                            <TextBlock Text="TAK"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                            <TextBlock FontSize="12"
                                       TextAlignment="Left"
                                       HorizontalAlignment="Stretch"
                                       Margin="0,10,0,0">
                                <Span>rekaman data aktivitas</Span>
                                <LineBreak/>
                                <Span>kemahasiswaan setiap mahasiswa</Span>
                                <LineBreak/>
                                <Span>di Telkom University</Span>
                            </TextBlock>
                            <FontIcon Glyph="&#xE8A7;"
                                      Margin="0,20,0,0"
                                      HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Item 11 -->
                <Grid Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}" CornerRadius="4">
                    <Button Click="ServiceDeskSitu_Click"
                            Height="250"
                            Width="211"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <Image Source="ms-appx:///Assets/Img_Logo_Situ.png"
                                   Margin="0,0,50,10"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Top"
                                   Width="80"
                                   Height="65"/>
                            <TextBlock Text="Service Desk PUTI"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                            <TextBlock FontSize="12"
                                       TextAlignment="Left"
                                       HorizontalAlignment="Stretch"
                                       Margin="0,10,0,0">
                                <Span>layanan keluhan dan permintaan</Span>
                                <LineBreak/>
                                <Span>terkait layanan TI Direktorat Pusat</Span>
                                <LineBreak/>
                                <Span>Teknologi Informasi (PUTI)</Span>
                            </TextBlock>
                            <FontIcon Glyph="&#xE8A7;"
                                      Margin="0,20,0,0"
                                      HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Button>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- Bottom Left: Tools Settings -->
        <Grid HorizontalAlignment="Left" VerticalAlignment="Bottom">
            <Grid Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                  Margin="0,0,40,30"
                  CornerRadius="10">
                <Button FontWeight="SemiBold"
                        FontSize="14"
                        Height="40"
                        Click="CommunityTool_Click">
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xE713;" Margin="0,0,10,0"/>
                        <TextBlock Text="Tools Settings"/>
                    </StackPanel>
                    <FlyoutBase.AttachedFlyout>
                        <Flyout x:Name="PageSettupFlyout">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="10"
                                        Padding="-7,-7,-7,-7">
                                <StackPanel HorizontalAlignment="Stretch"
                                            Spacing="10">
                                    <TextBlock Text="Miscellaneous"
                                               FontWeight="SemiBold"
                                               FontSize="18"/>
                                    <ToggleSwitch OffContent="Hide Application List"
                                                  OnContent="Show Application List"
                                                  FontWeight="SemiBold"
                                                  Toggled="Applicationlist_Toggle"
                                                  IsOn="True"/>
                                </StackPanel>
                            </StackPanel>
                        </Flyout>
                    </FlyoutBase.AttachedFlyout>
                </Button>
            </Grid>
        </Grid>

        <!-- Bottom Right: Community Tools -->
        <Grid HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Grid Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                  Margin="0,0,0,30"
                  CornerRadius="10">
                <Button FontWeight="SemiBold"
                        FontSize="14"
                        Height="40"
                        Click="CommunityTool_Click">
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xEB41;" Margin="0,0,10,0"/>
                        <TextBlock Text="Community Tools"/>
                    </StackPanel>
                    <FlyoutBase.AttachedFlyout>
                        <Flyout x:Name="CustomFlyout">
                            <StackPanel Spacing="12" Padding="-7,-7,-7,-7">
                                <!-- Tools and Community Tools in horizontal layout -->
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <StackPanel HorizontalAlignment="Stretch"
                                                Spacing="10">
                                        <TextBlock Text="Tools"
                                                   FontWeight="SemiBold"
                                                   FontSize="18"/>
                                        <ItemsControl ItemsSource="{x:Bind ViewModel.Tools, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="models:ToolItem">
                                                    <Button FontWeight="SemiBold"
                                                            HorizontalAlignment="Stretch"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Click="ToolButton_Click"
                                                            Tag="{x:Bind Url}"
                                                            HorizontalContentAlignment="Left"
                                                            Margin="0,0,0,10">
                                                        <StackPanel Orientation="Horizontal"
                                                                    HorizontalAlignment="Left">
                                                            <TextBlock Text="{x:Bind Icon}" Margin="0,0,8,0"/>
                                                            <TextBlock Text="{x:Bind Name}"/>
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                    <StackPanel HorizontalAlignment="Stretch"
                                                Spacing="10">
                                        <TextBlock Text="Community Tools"
                                                   FontWeight="SemiBold"
                                                   FontSize="18"/>
                                        <ItemsControl ItemsSource="{x:Bind ViewModel.CommunityTools, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="models:ToolItem">
                                                    <Button FontWeight="SemiBold"
                                                            HorizontalAlignment="Stretch"
                                                            Click="ToolButton_Click"
                                                            Tag="{x:Bind Url}"
                                                            HorizontalContentAlignment="Left"
                                                            Margin="0,0,0,10">
                                                        <StackPanel Orientation="Horizontal"
                                                                    HorizontalAlignment="Left">
                                                            <TextBlock Text="{x:Bind Icon}" Margin="0,0,8,0"/>
                                                            <TextBlock Text="{x:Bind Name}"/>
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                                
                                <!-- Manage Tools Footer -->
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Manage tools"
                                               VerticalAlignment="Center"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               FontSize="12"/>
                                    <HyperlinkButton x:Name="EditToolsButton"
                                                     Grid.Column="1"
                                                     Click="EditToolsButton_Click"
                                                     Padding="4,2"
                                                     FontSize="12"
                                                     Content="Edit"/>
                                </Grid>
                            </StackPanel>
                        </Flyout>
                    </FlyoutBase.AttachedFlyout>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</Page>
