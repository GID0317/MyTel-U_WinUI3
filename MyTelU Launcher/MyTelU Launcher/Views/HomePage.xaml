                                           HorizontalAlignment="Center" TextAlignment="Center"
                                           FontSize="20" Margin="0,8,0,0" FontWeight="SemiBold"/>
                                <TextBlock FontSize="12" TextAlignment="Left"
                                           HorizontalAlignment="Stretch" Margin="0,8,0,0">
                                    <Span>layanan civitas akademik Telkom</Span>
                                    <LineBreak/>
                                    <Span>University terkait kebutuhan</Span>
