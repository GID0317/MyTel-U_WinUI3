                                           HorizontalAlignment="Center" TextAlignment="Center"
                                           FontSize="20" Margin="0,8,0,0" FontWeight="SemiBold"/>
                                <TextBlock FontSize="12" TextAlignment="Left"
                                           HorizontalAlignment="Stretch" Margin="0,8,0,0">
                                    <Span>lakukan mobilisasi atau berkegiatan</Span>
                                    <LineBreak/>
                                    <Span>di lingkungan Telkom University</Span>
                                </TextBlock>
                            </StackPanel>
                            <FontIcon Glyph="&#xE8A7;"
                                      Margin="0,0,2,8" VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
