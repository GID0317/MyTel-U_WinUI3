<Page
    x:Class="MyTelU_Launcher.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:MyTelU_Launcher.Helpers"
    xmlns:xaml="using:Microsoft.UI.Xaml"
    xmlns:ui="using:Microsoft.UI.Xaml.Controls"
    xmlns:behaviors="using:MyTelU_Launcher.Behaviors"
    behaviors:NavigationViewHeaderBehavior.HeaderMode="Never"
    NavigationCacheMode="Required"
    mc:Ignorable="d"
    DataContext="{Binding ViewModel, RelativeSource={RelativeSource Self}}">

    <Page.Resources>
        <!-- Converter for friendly theme names -->
        <helpers:ThemeToStringConverter x:Key="ThemeToStringConverter" />
    </Page.Resources>

    <!-- Root Grid for layering -->
    <Grid>
        <!-- Background Layer: Full-size acrylic rectangle that is immune to content margins -->
        <Rectangle Fill="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
           HorizontalAlignment="Stretch"
           VerticalAlignment="Stretch"
           Margin="-100,-100,-100,-100"/>

        <!-- Foreground Content Layer -->
        <Grid Margin="20,20,20,20">

            <ScrollViewer VerticalScrollBarVisibility="Auto" VerticalScrollMode="Auto">
            <StackPanel x:Name="ContentArea" Spacing="5">
                <StackPanel.ChildrenTransitions>
                    <RepositionThemeTransition />
                </StackPanel.ChildrenTransitions>
                <TextBlock FontWeight="SemiBold" Text="Settings" Margin="3,20,5,5" FontSize="32"/>
                <!-- SettingsCard with Theme Changer ComboBox as its content -->
                <controls:SettingsCard x:Name="ThemeSettingsCard"
                                       Header="App Theme"
                                       Margin="0,0,0,0"
                                       Description="Select which app theme to display">
                    <controls:SettingsCard.HeaderIcon>
                        <ui:FontIcon Glyph="&#xE790;" />
                    </controls:SettingsCard.HeaderIcon>
                    <ComboBox
                        x:Uid="Settings_Theme_ComboBox"
                        ItemsSource="{x:Bind ViewModel.Themes, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.ElementTheme, Mode=TwoWay}"
                        FontSize="15">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="xaml:ElementTheme">
                                <TextBlock Text="{Binding Converter={StaticResource ThemeToStringConverter}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </controls:SettingsCard>

                <controls:SettingsExpander Description="Use custom background image by picking an image from directory" 
                           Header="Custom background image" 
                           IsExpanded="True">
                    <controls:SettingsExpander.HeaderIcon>
                        <ui:FontIcon Glyph="&#xEE71;" />
                    </controls:SettingsExpander.HeaderIcon>
                    <ToggleSwitch x:Name="CostumImageBGToggleSwitch" IsOn="{x:Bind ViewModel.IsCustomImageBGEnabled, Mode=TwoWay}"/>
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard x:Name="CostumImageBGTxt" 
                               Header="Pick an image from directory">
                            <controls:SettingsCard.Description>
                                <TextBlock IsTextSelectionEnabled="True"
                                           Text="{x:Bind ViewModel.CustomImagePathDescription, Mode=OneWay}" />
                            </controls:SettingsCard.Description>
                            <Button x:Name="CostumImageBGBtn" 
                    Content="Select Image" 
                    Style="{StaticResource AccentButtonStyle}" 
                    MinWidth="130"
                    IsEnabled="{x:Bind ViewModel.IsCustomImageBGEnabled, Mode=OneWay}"
                    Click="CostumImageBGBtn_Click"/>
                        </controls:SettingsCard>
                        <controls:SettingsCard Header="Open image location">
                            <Button Content="Open Location"
                                    MinWidth="130"
                                    IsEnabled="{x:Bind ViewModel.IsCustomImageBGEnabled, Mode=OneWay}"
                                    Click="OpenImageLocationBtn_Click"/>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>
                <!-- Tools Management Card -->
                <controls:SettingsCard x:Name="ToolsManagementCard"
                       Header="Reset Tools"
                       Margin="0,0,0,0"
                       Description="Restore default tools and remove all customizations">
                    <controls:SettingsCard.HeaderIcon>
                        <ui:FontIcon Glyph="&#xE7AD;" />
                    </controls:SettingsCard.HeaderIcon>
                    <Button Content="Reset" Click="ResetToolsButton_Click"/>
                </controls:SettingsCard>
                <!-- Reset Success InfoBar -->
                <InfoBar
                x:Name="ResetSuccessInfoBar"
                IsOpen="True"
                Visibility="Collapsed"
                Severity="Success"
                Message="Tools have been reset to default successfully"
                IsClosable="False"/>

                <!-- Update Check Card -->
                <controls:SettingsCard x:Name="UpdateSettingsCard"
                       Header="Update Check"
                       Margin="0,0,0,0"
                       Description="Current version: 3.0.2">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE895;" />
                    </controls:SettingsCard.HeaderIcon>
                    <Button Content="Check for update" Click="CheckUpdateButton_Click"/>
                </controls:SettingsCard>

                <!-- InfoBar to display the update result when already up-to-date -->
                <InfoBar
                x:Name="UpdateUptodateInfoBar"
                IsOpen="True"
                Visibility="Collapsed"
                Severity="Success"
                Message="You are already up-to-date"
                IsClosable="False"/>

                <TextBlock FontWeight="SemiBold" Text="About" Margin="3,10,5,5"/>

                <controls:SettingsExpander Header="MyTel-U Launcher" 
                                           Description="Copyright © GID Under MIT License. All rights reserved."
                                           IsExpanded="True"
                                           Margin="0,0,0,0">
                    <controls:SettingsExpander.HeaderIcon>
                        <ui:ImageIcon Source="ms-appx:///Assets/Icon_App.png" />
                    </controls:SettingsExpander.HeaderIcon>
                    <TextBlock IsTextSelectionEnabled="True"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="Version 3.0.2" />
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard Header="Send a Feedback, File a bug or contribute to the project">
                            <HyperlinkButton Content="Go to the page"
                                             NavigateUri="https://github.com/GID0317/MyTel-U_WinUI3/issues/new/choose" />
                        </controls:SettingsCard>
                        <controls:SettingsCard Header="Help us with the translations">
                            <HyperlinkButton Content="Go to the page"
                                             NavigateUri="https://github.com/GID0317/MyTel-U_WinUI3" />
                        </controls:SettingsCard>
                        <controls:SettingsCard Header="Open Source contributors">
                            <HyperlinkButton Content="Go to the page"
                                              NavigateUri="https://github.com/GID0317/MyTel-U_WinUI3/graphs/contributors" />
                        </controls:SettingsCard>
                        <controls:SettingsCard HorizontalContentAlignment="Left"
                                                 ContentAlignment="Left">
                            <StackPanel Margin="-12,0,0,0" Orientation="Vertical">
                                <TextBlock Text="Dependencies  references" Padding="10,5,0,5"/>
                                <HyperlinkButton Content="Win App SDK 1.8" NavigateUri="https://github.com/microsoft/WindowsAppSDK"/>
                                <HyperlinkButton Content="Win UI Library" NavigateUri="https://learn.microsoft.com/en-us/windows/apps/winui/winui3/"/>
                                <HyperlinkButton Content="Windows Community Toolkit" NavigateUri="https://github.com/CommunityToolkit/Windows"/>
                            </StackPanel>
                        </controls:SettingsCard>
                        <controls:SettingsCard Header="Disclaimer: This application is not affiliated with Telkom University by any means and is completely open-sourced.">
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>
            </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>